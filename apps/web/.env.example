# Web app environment template.
# Copy this file to apps/web/.env.local only when local web config is needed.
# The user will manually add API keys later if a future feature requires them.
# Do not commit real secrets.

APP_ENV=development
LOCAL_DATA_DIR=../../data
DATABASE_URL=file:../../data/app.sqlite

# AI provider keys are planned for later. Leave blank until manually configured.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Platform credentials are planned for later. Real publishing remains disabled.
META_CLIENT_ID=
META_CLIENT_SECRET=
META_REDIRECT_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

INTEGRATIONS_MODE=mock
ENABLE_REAL_NETWORK_CALLS=false
ENABLE_REAL_OAUTH=false
ENABLE_REAL_PUBLISHING=false
TOKEN_STORAGE_MODE=placeholder_not_stored
ALLOW_INSECURE_TOKEN_STORAGE=false
